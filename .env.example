# Discord Bot Token (required)
DISCORD_TOKEN=your_bot_token_here

# Channel ID where Finn sends status messages on startup (optional)
STATUS_CHANNEL_ID=1287528424847708292

# VagaBot client ID for minigame reaction detection (optional)
VAGABOT_ID=1459925000311144498

# Ollama — set to your remote VM's IP for Proxmox deployment
OLLAMA_URL=http://192.168.1.100:11434

# Ollama model to use
OLLAMA_MODEL=llama3.2

# Proactive chatter settings
CHATTER_CHANCE=0.08         # 0.0–1.0, chance Finn randomly comments on messages
CHATTER_COOLDOWN_MS=90000   # milliseconds between random chats per channel (90s default)

# Minigame reaction chance (0.0–1.0)
REACTION_CHANCE=0.6

# n8n context server port (default: 3001, localhost-only)
CONTEXT_PORT=3001

# Music bot — comma-separated Discord role IDs that can use !gitarre
# Leave empty to allow everyone. Get IDs via Discord developer mode: right-click role → Copy ID
MUSIC_ROLE_IDS=123456789012345678,987654321098765432
